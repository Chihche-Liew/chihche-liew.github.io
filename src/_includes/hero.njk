<section id="hero" class="section-hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <h1 class="hero-name">{{ site.title }}</h1>
      <p class="hero-bio">{{ site.bio }}</p>
      <p class="hero-bio hero-bio-2">{{ site.bio2 }}</p>

      <ul class="edu-list">
        <li>
          <span class="edu-degree">Ph.D. Accounting</span>
          <span class="edu-meta"><span class="edu-school">Columbia University</span><span class="edu-year">Expected 2031</span></span>
        </li>
        <li>
          <span class="edu-degree">M.S. Data Science</span>
          <span class="edu-meta"><span class="edu-school">University of Wisconsin-Madison</span><span class="edu-year">2026</span></span>
        </li>
        <li>
          <span class="edu-degree">B.B.A. Supply Chain Management</span>
          <span class="edu-meta"><span class="edu-school">Wuhan University</span><span class="edu-year">2024</span></span>
        </li>
      </ul>

